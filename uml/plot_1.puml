  # _save_or_default(save_path: Path?, default_name: str): Path
}

class "Python stdlib" as Std {
  datetime
  pathlib.Path
  collections.defaultdict
  warnings
}

package "Matplotlib" as MPL {
  class matplotlib
  class "pyplot (plt)" as plt
  class "dates (mdates)" as mdates
  class "font_manager" as font_manager
}

Plotter ..> Std : ログ解析/日付処理/集計/保存先管理
Plotter ..> plt : plot(), bar(), savefig(), close()
Plotter ..> mdates : DayLocator / DateFormatter
Plotter ..> font_manager : 利用可能フォント探索
matplotlib ..> plt : backend設定(Agg)

