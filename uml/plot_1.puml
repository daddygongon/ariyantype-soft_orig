title Plotter.py の全体構成（1〜4を俯瞰）

class Plotter {
  - out_dir: Path
  + plot_speed_log(speed_log_path: Path, save_path: Path? = None): void
  + plot_training_scores(training_log_path: Path, save_path: Path? = None): void
  + plot_practiced_steps(training_log_path: Path, save_path: Path? = None): void
  --
  # _parse_datetime(s: str): datetime
  # _group_by_day_average(times, values): (days, avgs)
